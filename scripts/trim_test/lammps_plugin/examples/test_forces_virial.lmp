# Test script to output forces and virial for comparison with Python
# Uses slightly displaced Si atoms to get non-zero forces

units           metal
atom_style      atomic
boundary        p p p

# Load ACE plugin
plugin          load ../build/aceplugin.so

# Create Si diamond structure with small displacement
lattice         diamond 5.43
region          box block 0 1 0 1 0 1
create_box      1 box
create_atoms    1 box

mass            1 28.0855

# Displace atom 1 slightly to get non-zero forces
group           atom1 id 1
displace_atoms  atom1 move 0.05 0.03 -0.02 units box

# Set up ACE potential
pair_style      ace
pair_coeff      * * ../../silicon_lib/lib/libace.so Si

# Compute and output
compute         peratom all pe/atom
compute         stress all stress/atom NULL virial

# Dump positions and forces
dump            1 all custom 1 forces.dump id type x y z fx fy fz c_peratom c_stress[1] c_stress[2] c_stress[3] c_stress[4] c_stress[5] c_stress[6]
dump_modify     1 format float %20.12e

# Also output global virial
thermo_style    custom step pe pxx pyy pzz pxy pxz pyz
thermo          1

run             0

# Print summary
print           "Energy: $(pe) eV"
print           "Pressure tensor (bar): pxx=$(pxx) pyy=$(pyy) pzz=$(pzz) pxy=$(pxy) pxz=$(pxz) pyz=$(pyz)"
