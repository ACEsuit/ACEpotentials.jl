# Minimal test script for ACE plugin

units           metal
atom_style      atomic
boundary        p p p

# Load ACE plugin
plugin          load ../build/aceplugin.so

# Create simple Si structure
lattice         diamond 5.43
region          box block 0 1 0 1 0 1
create_box      1 box
create_atoms    1 box

mass            1 28.0855

# Set up ACE potential
pair_style      ace
pair_coeff      * * ../../silicon_lib/lib/libace.so Si

# Compute energy
run             0

# Print energy
print           "Total energy: $(pe) eV"
print           "Per-atom energy: $(pe/atoms) eV/atom"
